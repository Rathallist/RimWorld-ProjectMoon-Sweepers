<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- ===================================================================
       BASE ABSTRAITE : Armure Sweeper
       Plaques métalliques bleu-gris boulonnées par-dessus la combinaison.
       Différent du corps du Sweeper — ce sont des équipements additionnels.
       Material : acier + composants industriels + Carburant Vital (joints)
  =================================================================== -->

  <ThingDef Name="PM_SweeperArmorBase" ParentName="ApparelBase" Abstract="True">
    <thingClass>Apparel</thingClass>
    <category>Item</category>
    <techLevel>Spacer</techLevel>
    <tradeability>All</tradeability>      <!-- Vendable par les caravanes Sweeper -->
    <tradeTags>
      <li>None</li>
    </tradeTags>
    <thingSetMakerTags>
      <li>RewardStandardLowFreq</li>
    </thingSetMakerTags>
    <statBases>
      <Flammability>0.0</Flammability>
    </statBases>
  </ThingDef>


  <!-- ===================================================================
       CASQUE : Casque de Sweeper
       Helm anguleux, oeil rouge unique, plaques vissées.
       Visible sur les 3 images — caractéristique des Sweepers.
       Slot : Head
  =================================================================== -->

  <ThingDef ParentName="PM_SweeperArmorBase">
    <defName>PM_Armor_SweeperHelm</defName>
    <label>casque de Sweeper</label>
    <description>Un casque anguleux aux plaques de métal bleu-gris, forgé pour protéger la "tête" du Sweeper — en réalité le nœud de conscience supérieur de son corps liquide. Une lentille rouge unique remplace l'œil. Les joints sont scellés avec du Carburant Vital cristallisé.</description>

    <graphicData>
      <texPath>Things/Pawn/Humanlike/Apparel/PM_SweeperHelm/PM_SweeperHelm</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>

    <statBases>
      <MaxHitPoints>200</MaxHitPoints>
      <Mass>3.5</Mass>
      <MarketValue>180</MarketValue>
      <!-- Protection élevée : plaque de métal solide -->
      <ArmorRating_Sharp>0.60</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.45</ArmorRating_Blunt>
      <ArmorRating_Heat>0.25</ArmorRating_Heat>
      <Insulation_Cold>5</Insulation_Cold>
      <Insulation_Heat>-5</Insulation_Heat>
    </statBases>

    <costList>
      <Steel>40</Steel>
      <ComponentIndustrial>2</ComponentIndustrial>
    </costList>

    <apparel>
      <bodyPartGroups>
        <li>FullHead</li>
      </bodyPartGroups>
      <wornGraphicPath>Things/Pawn/Humanlike/Apparel/PM_SweeperHelm/PM_SweeperHelm</wornGraphicPath>
      <layers>
        <li>Overhead</li>
        <li>EyeCover</li>
      </layers>
      <hatRenderedFrontOfFace>true</hatRenderedFrontOfFace>
      <shellRenderedBehindHead>false</shellRenderedBehindHead>
    </apparel>

    <recipeMaker>
      <researchPrerequisite>PM_Research_SweeperArmor</researchPrerequisite>
      <workAmount>1200</workAmount>
      <skillRequirements>
        <Crafting>5</Crafting>
      </skillRequirements>
      <workSkill>Crafting</workSkill>
      <recipeUsers>
        <li>ElectricSmithy</li>
        <li>FueledSmithy</li>
      </recipeUsers>
    </recipeMaker>
  </ThingDef>


  <!-- ===================================================================
       TORSE : Plastron de Sweeper
       Grande plaque hexagonale centrale + épaulières.
       Très visible image 2 et 3.
       Slot : Torso (outer)
  =================================================================== -->

  <ThingDef ParentName="PM_SweeperArmorBase">
    <defName>PM_Armor_SweeperChest</defName>
    <label>plastron de Sweeper</label>
    <description>Un plastron massif composé de plusieurs plaques hexagonales imbriquées, fixées par des vis de métal. Les épaulières intégrées protègent les "épaules" du Sweeper. De légères fissures dans le métal laissent parfois voir la lueur rouge du Carburant Vital en dessous.</description>

    <graphicData>
      <texPath>Things/Pawn/Humanlike/Apparel/PM_SweeperChest/PM_SweeperChest</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>

    <statBases>
      <MaxHitPoints>350</MaxHitPoints>
      <Mass>8.0</Mass>
      <MarketValue>280</MarketValue>
      <ArmorRating_Sharp>0.72</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.55</ArmorRating_Blunt>
      <ArmorRating_Heat>0.30</ArmorRating_Heat>
      <Insulation_Cold>8</Insulation_Cold>
      <Insulation_Heat>-8</Insulation_Heat>
    </statBases>

    <costList>
      <Steel>80</Steel>
      <ComponentIndustrial>4</ComponentIndustrial>
    </costList>

    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Shoulders</li>
      </bodyPartGroups>
      <wornGraphicPath>Things/Pawn/Humanlike/Apparel/PM_SweeperChest/PM_SweeperChest</wornGraphicPath>
      <layers>
        <li>Shell</li>
      </layers>
    </apparel>

    <recipeMaker>
      <researchPrerequisite>PM_Research_SweeperArmor</researchPrerequisite>
      <workAmount>2000</workAmount>
      <skillRequirements>
        <Crafting>6</Crafting>
      </skillRequirements>
      <workSkill>Crafting</workSkill>
      <recipeUsers>
        <li>ElectricSmithy</li>
        <li>FueledSmithy</li>
      </recipeUsers>
    </recipeMaker>
  </ThingDef>


  <!-- ===================================================================
       JAMBES : Jambières de Sweeper
       Protège-tibias et genouillères segmentés.
       Bien visibles sur les 3 images, plaques articulées.
       Slot : Legs (outer)
  =================================================================== -->

  <ThingDef ParentName="PM_SweeperArmorBase">
    <defName>PM_Armor_SweeperLegs</defName>
    <label>jambières de Sweeper</label>
    <description>Des protège-tibias et genouillères en métal segmenté, articulés pour permettre le mouvement rapide du Sweeper. Chaque segment est indépendant, ce qui permet de remplacer les pièces endommagées individuellement. Les attaches inférieures sont renforcées avec du Carburant Vital cristallisé pour absorber les vibrations au sol.</description>

    <graphicData>
      <texPath>Things/Item/Apparel/PM_SweeperLegs_icon</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>

    <statBases>
      <MaxHitPoints>280</MaxHitPoints>
      <Mass>5.0</Mass>
      <MarketValue>160</MarketValue>
      <ArmorRating_Sharp>0.55</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.48</ArmorRating_Blunt>
      <ArmorRating_Heat>0.20</ArmorRating_Heat>
      <Insulation_Cold>5</Insulation_Cold>
      <Insulation_Heat>-5</Insulation_Heat>
      <!-- Légère pénalité de vitesse : les plaques sont lourdes -->
      <MoveSpeed>-0.1</MoveSpeed>
    </statBases>

    <costList>
      <Steel>60</Steel>
      <ComponentIndustrial>2</ComponentIndustrial>
    </costList>

    <apparel>
      <bodyPartGroups>
        <li>Legs</li>
      </bodyPartGroups>
      <wornGraphicPath>Things/Pawn/Humanlike/Apparel/PM_SweeperLegs/PM_SweeperLegs</wornGraphicPath>
      <layers>
        <li>Shell</li>
      </layers>
    </apparel>

    <recipeMaker>
      <researchPrerequisite>PM_Research_SweeperArmor</researchPrerequisite>
      <workAmount>1500</workAmount>
      <skillRequirements>
        <Crafting>5</Crafting>
      </skillRequirements>
      <workSkill>Crafting</workSkill>
      <recipeUsers>
        <li>ElectricSmithy</li>
        <li>FueledSmithy</li>
      </recipeUsers>
    </recipeMaker>
  </ThingDef>


  <!-- ===================================================================
       BRAS : Brassards de Sweeper
       Protège-avant-bras segmentés, visibles image 1 et 3.
       Slot : Arms (outer)
  =================================================================== -->

  <ThingDef ParentName="PM_SweeperArmorBase">
    <defName>PM_Armor_SweeperArms</defName>
    <label>brassards de Sweeper</label>
    <description>Des protège-avant-bras segmentés qui protègent les membres du Sweeper tout en laissant une liberté de mouvement maximale pour manier les Hooks. Les articulations au niveau du coude sont renforcées d'un alliage plus souple pour ne pas entraver les rotations de lame.</description>

    <graphicData>
      <texPath>Things/Pawn/Humanlike/Apparel/PM_SweeperArms/PM_SweeperArms</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>

    <statBases>
      <MaxHitPoints>220</MaxHitPoints>
      <Mass>3.0</Mass>
      <MarketValue>120</MarketValue>
      <ArmorRating_Sharp>0.50</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.42</ArmorRating_Blunt>
      <ArmorRating_Heat>0.18</ArmorRating_Heat>
    </statBases>

    <costList>
      <Steel>45</Steel>
      <ComponentIndustrial>2</ComponentIndustrial>
    </costList>

    <apparel>
      <bodyPartGroups>
        <li>Arms</li>
      </bodyPartGroups>
      <wornGraphicPath>Things/Pawn/Humanlike/Apparel/PM_SweeperArms/PM_SweeperArms</wornGraphicPath>
      <layers>
        <li>Shell</li>
      </layers>
    </apparel>

    <recipeMaker>
      <researchPrerequisite>PM_Research_SweeperArmor</researchPrerequisite>
      <workAmount>1200</workAmount>
      <skillRequirements>
        <Crafting>5</Crafting>
      </skillRequirements>
      <workSkill>Crafting</workSkill>
      <recipeUsers>
        <li>ElectricSmithy</li>
        <li>FueledSmithy</li>
      </recipeUsers>
    </recipeMaker>
  </ThingDef>


  <!-- ===================================================================
       SET COMPLET : Armure Lourde de Sweeper (variante image 1 et 3)
       Réservoir dorsal agrandi, plaques plus épaisses.
       Couvre le torse + réservoir — slot Shell étendu.
       Bonus de stockage de Carburant Vital intégré (logique C# plus tard).
  =================================================================== -->

  <ThingDef ParentName="PM_SweeperArmorBase">
    <defName>PM_Armor_SweeperHeavyChest</defName>
    <label>plastron lourd de Sweeper</label>
    <description>Une version renforcée du plastron standard, avec un réservoir dorsal intégré plus grand et des plaques avant doublées. Le réservoir visible dans le dos peut contenir plus de Carburant Vital, permettant au Sweeper lourd de rester plus longtemps en combat sans se ravitailler. Extrêmement lourd — réservé aux Sweepers à forte constitution.</description>

    <graphicData>
      <texPath>Things/Pawn/Humanlike/Apparel/PM_SweeperHeavyChest/PM_SweeperHeavyChest</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>

    <statBases>
      <MaxHitPoints>500</MaxHitPoints>
      <Mass>14.0</Mass>
      <MarketValue>450</MarketValue>
      <ArmorRating_Sharp>0.82</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.68</ArmorRating_Blunt>
      <ArmorRating_Heat>0.40</ArmorRating_Heat>
      <Insulation_Cold>12</Insulation_Cold>
      <Insulation_Heat>-10</Insulation_Heat>
      <!-- Pénalité significative de vitesse -->
      <MoveSpeed>-0.4</MoveSpeed>
    </statBases>

    <costList>
      <Steel>150</Steel>
      <ComponentIndustrial>8</ComponentIndustrial>
      <ComponentSpacer>2</ComponentSpacer>
    </costList>

    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Shoulders</li>
        <li>Neck</li>
      </bodyPartGroups>
      <wornGraphicPath>Things/Pawn/Humanlike/Apparel/PM_SweeperHeavyChest/PM_SweeperHeavyChest</wornGraphicPath>
      <layers>
        <li>Shell</li>
      </layers>
      <!-- Incompatible avec le plastron standard -->
      <countsAsClothingForNudity>false</countsAsClothingForNudity>
    </apparel>

    <recipeMaker>
      <researchPrerequisite>PM_Research_SweeperArmor</researchPrerequisite>
      <workAmount>4000</workAmount>
      <skillRequirements>
        <Crafting>8</Crafting>
      </skillRequirements>
      <workSkill>Crafting</workSkill>
      <recipeUsers>
        <li>ElectricSmithy</li>
        <li>FueledSmithy</li>
      </recipeUsers>
    </recipeMaker>
  </ThingDef>


  <!-- ===================================================================
       RECETTES EXPLICITES pour la Mother
       (complète les recipeMaker définis dans chaque ThingDef)
  =================================================================== -->

</Defs>
