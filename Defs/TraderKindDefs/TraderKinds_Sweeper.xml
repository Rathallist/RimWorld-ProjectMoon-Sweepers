<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- =====================================================================
       MARCHANDS SWEEPER
       Ce que vendent les caravanes/visiteurs/bases Sweeper : carburant vital,
       cristalliseurs d'urgence, armes (Hooks) et armures Sweeper, plus un fond
       de marchandises génériques.
  ===================================================================== -->

  <!-- Caravane marchande Sweeper -->
  <TraderKindDef>
    <defName>PM_Caravan_Sweeper</defName>
    <label>caravane sweeper</label>
    <stockGenerators>
      <!-- Silver -->
      <li Class="StockGenerator_SingleDef">
        <thingDef>Silver</thingDef>
        <countRange>500~1500</countRange>
      </li>
      <!-- Carburant vital -->
      <li Class="StockGenerator_SingleDef">
        <thingDef>PM_RedLiquidResource</thingDef>
        <countRange>30~120</countRange>
      </li>
      <!-- Cristalliseurs d'urgence -->
      <li Class="StockGenerator_SingleDef">
        <thingDef>PM_EmergencyCrystallizer</thingDef>
        <countRange>2~8</countRange>
      </li>
      <!-- Armes : Hooks -->
      <li Class="StockGenerator_SingleDef">
        <thingDef>PM_Hook_Standard</thingDef>
        <countRange>1~4</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>PM_Hook_Heavy</thingDef>
        <countRange>0~2</countRange>
      </li>
      <!-- Armures Sweeper -->
      <li Class="StockGenerator_SingleDef">
        <thingDef>PM_Armor_SweeperChest</thingDef>
        <countRange>0~3</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>PM_Armor_SweeperHelm</thingDef>
        <countRange>0~3</countRange>
      </li>
      <!-- Réservoirs dorsaux -->
      <li Class="StockGenerator_SingleDef">
        <thingDef>PM_BackTank_Medium</thingDef>
        <countRange>0~2</countRange>
      </li>
      <!-- Marchandises communes -->
      <li Class="StockGenerator_Category">
        <categoryDef>FoodRaw</categoryDef>
        <thingDefCountRange>2~4</thingDefCountRange>
        <totalPriceRange>200~600</totalPriceRange>
      </li>
      <li Class="StockGenerator_Category">
        <categoryDef>Medicine</categoryDef>
        <thingDefCountRange>1~2</thingDefCountRange>
        <totalPriceRange>150~400</totalPriceRange>
      </li>
      <li Class="StockGenerator_Category">
        <categoryDef>Apparel</categoryDef>
        <thingDefCountRange>2~4</thingDefCountRange>
        <totalPriceRange>200~700</totalPriceRange>
      </li>
    </stockGenerators>
  </TraderKindDef>
  <TraderKindDef>
    <defName>PM_Visitor_Sweeper</defName>
    <label>marchand sweeper</label>
    <stockGenerators>
      <li Class="StockGenerator_SingleDef">
        <thingDef>Silver</thingDef>
        <countRange>300~800</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>PM_RedLiquidResource</thingDef>
        <countRange>15~60</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>PM_EmergencyCrystallizer</thingDef>
        <countRange>1~4</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>PM_Hook_Standard</thingDef>
        <countRange>0~2</countRange>
      </li>
      <li Class="StockGenerator_Category">
        <categoryDef>FoodRaw</categoryDef>
        <thingDefCountRange>1~3</thingDefCountRange>
        <totalPriceRange>100~300</totalPriceRange>
      </li>
      <li Class="StockGenerator_Category">
        <categoryDef>Medicine</categoryDef>
        <thingDefCountRange>1~1</thingDefCountRange>
        <totalPriceRange>80~200</totalPriceRange>
      </li>
    </stockGenerators>
  </TraderKindDef>

  <!-- Base Sweeper (settlement) -->
  <TraderKindDef>
    <defName>PM_Base_Sweeper</defName>
    <label>colonie sweeper</label>
    <stockGenerators>
      <li Class="StockGenerator_SingleDef">
        <thingDef>Silver</thingDef>
        <countRange>800~2000</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>PM_RedLiquidResource</thingDef>
        <countRange>60~200</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>PM_EmergencyCrystallizer</thingDef>
        <countRange>4~12</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>PM_Hook_Standard</thingDef>
        <countRange>2~6</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>PM_Hook_Heavy</thingDef>
        <countRange>1~3</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>PM_Armor_SweeperChest</thingDef>
        <countRange>1~4</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>PM_Armor_SweeperHelm</thingDef>
        <countRange>1~4</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>PM_Armor_SweeperLegs</thingDef>
        <countRange>1~4</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>PM_Armor_SweeperArms</thingDef>
        <countRange>1~4</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>PM_BackTank_Medium</thingDef>
        <countRange>1~3</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>PM_BackTank_Large</thingDef>
        <countRange>0~2</countRange>
      </li>
      <!-- Marchandises communes -->
      <li Class="StockGenerator_Category">
        <categoryDef>FoodRaw</categoryDef>
        <thingDefCountRange>3~5</thingDefCountRange>
        <totalPriceRange>300~800</totalPriceRange>
      </li>
      <li Class="StockGenerator_Category">
        <categoryDef>Medicine</categoryDef>
        <thingDefCountRange>1~2</thingDefCountRange>
        <totalPriceRange>200~500</totalPriceRange>
      </li>
      <li Class="StockGenerator_Category">
        <categoryDef>Apparel</categoryDef>
        <thingDefCountRange>3~6</thingDefCountRange>
        <totalPriceRange>300~900</totalPriceRange>
      </li>
    </stockGenerators>
  </TraderKindDef>

</Defs>
