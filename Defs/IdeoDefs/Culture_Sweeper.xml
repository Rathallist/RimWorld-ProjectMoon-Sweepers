<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <CultureDef MayRequire="Ludeon.RimWorld.Ideology">
    <defName>PM_Culture_Sweeper</defName>
    <label>sweeper</label>
    <description>Les bandes de Sweepers se divisent en "familles" et s'appellent par des termes familiaux ou cordiaux — frère, oncle, voisin. Ces familles ne reflètent pas de liens de sang, mais une affection métaphorique. Les Sweepers veillent les uns sur les autres et respectent les résidents des Backstreets. Mais dès que commence la Nuit dans les Backstreets, tout devient déchet.</description>
    <ideoNameMaker MayRequire="Ludeon.RimWorld.Ideology">NamerIdeoAstropolitan</ideoNameMaker>
    <deityNameMaker MayRequire="Ludeon.RimWorld.Ideology">NamerDeityAstropolitan</deityNameMaker>
    <deityTypeMaker MayRequire="Ludeon.RimWorld.Ideology">DeityTypeMakerAstropolitan</deityTypeMaker>
    <leaderTitleMaker MayRequire="Ludeon.RimWorld.Ideology">LeaderTitleMaker_Astropolitan</leaderTitleMaker>
    <festivalNameMaker MayRequire="Ludeon.RimWorld.Ideology">NamerFestivalAstropolitan</festivalNameMaker>
    <iconPath>UI/Cultures/PM_Culture_Sweeper</iconPath>
    <allowedPlaceTags>
      <li>OriginSpacer</li>
    </allowedPlaceTags>
